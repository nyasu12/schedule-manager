{
  "name": "schedule-manager-cloudflare",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "db:migrate:remote": "wrangler d1 migrations apply schedule-manager-db --remote",
    "db:migrate:local": "wrangler d1 migrations apply schedule-manager-db --local",
    "user:set": "node scripts/set-user.mjs",
    "build": "node scripts/build.mjs"
  },
  "devDependencies": {
    "wrangler": "^4.113.0"
  },
  "description": "Configurable schedule and resource management web application built with Cloudflare Workers, D1, and R2, with optional Travel integrations."
}
