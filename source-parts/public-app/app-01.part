'use strict';

const $ = (id) => document.getElementById(id);
const qs = (selector, root = document) => root.querySelector(selector);
const qsa = (selector, root = document) => [...root.querySelectorAll(selector)];

const state = {
  data: { user: null, regions: [], purposes: [], holidays: [], companies: [], stores: [], employees: [], cars: [], schedules: [], usage: { flight: 0, flightLimit: 300, vision: 0, visionLimit: 900, openai: 0, openaiLimit: 300, openaiWeb: 0, openaiWebLimit: 100 } },
  mode: 'month',
  viewMonth: new Date(new Date().getFullYear(), new Date().getMonth(), 1),
  selectedDate: localDateString(new Date()),
  masterType: 'company',
};

function localDateString(date) {
  const y = date.getFullYear();
  const m = String(date.getMonth() + 1).padStart(2, '0');
  const d = String(date.getDate()).padStart(2, '0');
  return `${y}-${m}-${d}`;
}
function escapeHtml(value) {
  return String(value ?? '').replace(/[&<>'"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', "'": '&#39;', '"': '&quot;' }[c]));
}
function fmtDate(value) {
  if (!value) return '—';
  const d = new Date(`${value}T00:00:00`);
  if (Number.isNaN(d.getTime())) return value;
  return `${d.getMonth() + 1}月${d.getDate()}日（${'日月火水木金土'[d.getDay()]}）`;
}
function toast(message, ms = 2200) {
  const el = $('toast');
  el.textContent = String(message || '');
  el.classList.add('show');
  clearTimeout(toast.timer);
  toast.timer = setTimeout(() => el.classList.remove('show'), ms);
}
function setBanner(message = '', error = false) {
  const el = $('statusBanner');
  el.textContent = message;
  el.classList.toggle('error', error);
  el.classList.toggle('ready', !message);
}
function openModal(id) { $(id).hidden = false; }
function closeModal(id) { $(id).hidden = true; }
function isEditor() { return ['manager', 'admin'].includes(state.data.user?.role); }
function isTimeEditor() { return state.data.user?.role === 'time_editor'; }
function canEditDepartureTime() { return ['time_editor','manager','admin'].includes(state.data.user?.role); }
function isAdmin() { return state.data.user?.role === 'admin'; }
function formatJstTimestamp(value) {
  if (!value) return '';
  let raw = String(value).trim();
  // SQLite CURRENT_TIMESTAMP is UTC but has no timezone suffix.
  if (/^\d{4}-\d{2}-\d{2} \d{2}:\d{2}(?::\d{2})?$/.test(raw)) raw = raw.replace(' ', 'T') + (raw.length === 16 ? ':00Z' : 'Z');
  const d = new Date(raw);
  if (Number.isNaN(d.getTime())) return String(value);
  const parts = Object.fromEntries(new Intl.DateTimeFormat('en-CA', {
    timeZone: 'Asia/Tokyo', year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: false,
  }).formatToParts(d).filter((x) => x.type !== 'literal').map((x) => [x.type, x.value]));
  return `${parts.year}/${parts.month}/${parts.day} ${parts.hour}:${parts.minute}:${parts.second} JST`;
}

async function api(url, options = {}) {
  const opts = { ...options, headers: { ...(options.headers || {}) } };
  if (opts.body && !(opts.body instanceof FormData) && typeof opts.body !== 'string') {
    opts.headers['content-type'] = 'application/json';
    opts.body = JSON.stringify(opts.body);
  }
  const response = await fetch(url, opts);
  const type = response.headers.get('content-type') || '';
  const payload = type.includes('application/json') ? await response.json().catch(() => ({})) : await response.text();
  if (!response.ok || payload?.ok === false) {
    const message = typeof payload === 'object' ? (payload.error || payload.details || `HTTP ${response.status}`) : (payload || `HTTP ${response.status}`);
    throw new Error(String(message));
  }
  return payload;
}

function purposeName(id) { return state.data.purposes.find((x) => x.id === id)?.name || id || '予定'; }
function regionName(id) { return state.data.regions.find((x) => x.id === id)?.name || id || ''; }
function companyById(id) { return state.data.companies.find((x) => x.id === id); }
function storeById(id) { return state.data.stores.find((x) => x.id === id); }
function employeeById(id) { return state.data.employees.find((x) => x.id === id); }
function carById(id) { return state.data.cars.find((x) => x.id === id); }
function scheduleColors(schedule) {
  const colors = schedule.stores.map((x) => companyById(x.companyId)?.color).filter(Boolean);
  return [...new Set(colors.length ? colors : ['#aeb9c7'])];
}
function colorStrip(colors) {
  return `<div class="company-strip">${colors.map((c) => `<i style="background:${escapeHtml(c)}"></i>`).join('')}</div>`;
}
function scheduleMissingReasons(schedule) {
  const reasons = [];
  if (!schedule.departureTime) reasons.push('出発時刻');
  if (!schedule.employees?.length) reasons.push('担当者');
  if (!schedule.cars?.length) reasons.push('車両');
  if (schedule.purposeId === 'APT' && !schedule.flights?.length) reasons.push('航空便');
  return reasons;
}
function isIncomplete(schedule) { return scheduleMissingReasons(schedule).length > 0; }
function arrivalTotal(schedule) { return (schedule.stores || []).reduce((n, x) => n + Number(x.arrivalCount || 0), 0); }
function departureTotal(schedule) { return (schedule.stores || []).reduce((n, x) => n + Number(x.departureCount || 0), 0); }
function storeSummary(schedule) {
  if (!schedule.stores?.length) return '会社・店舗 未入力';
  return schedule.stores.map((r) => {
    const company = companyById(r.companyId)?.name || '会社未設定';
    const store = storeById(r.storeId)?.name || '店舗未設定';
    return `${company}／${store}`;
  }).join('、');
}
function employeeSummary(schedule) {
  if (!schedule.employees?.length) return '未入力・未定';
  return schedule.employees.map((id) => employeeById(id)?.name || id).join('、');
}
function carSummary(schedule) {
  if (!schedule.cars?.length) return '未入力・未定';
  return schedule.cars.map((id) => carById(id)?.name || id).join('、');
}
function flightSummary(f) {
  const ident = [f.airlineCode, f.flightNumber].filter(Boolean).join('') || '便名 未入力';
  const route = [f.origin, f.destination].filter(Boolean).join(' → ');
  const times = [f.scheduledDeparture, f.scheduledArrival].filter(Boolean).join(' → ');
  return [ident, route, times].filter(Boolean).join('　');
}
function flightDetailBox(f) {
  const originalTimes = [f.scheduledDeparture, f.scheduledArrival].filter(Boolean).join(' → ');
  const latestTimes = [f.changedDeparture, f.changedArrival].filter(Boolean).join(' → ');
  const sourceUrl = /^https?:\/\//i.test(f.checkUrl || '') ? f.checkUrl : '';
  const source = f.checkSource ? (sourceUrl ? `<a class="file-link" href="${escapeHtml(sourceUrl)}" target="_blank" rel="noopener">${escapeHtml(f.checkSource)}</a>` : escapeHtml(f.checkSource)) : '';
  return `<div class="flight-box"><div class="flight-head"><strong>${escapeHtml(f.direction || '航空便')} ${escapeHtml(flightSummary(f))}</strong><span>${escapeHtml(f.status || '未確認')}</span></div>${f.flightDate ? `<div>搭乗日：${escapeHtml(f.flightDate)}</div>` : ''}${originalTimes ? `<div><b>旅程表・登録時刻：</b>${escapeHtml(originalTimes)}</div>` : ''}${latestTimes ? `<div><b>最新確認：</b>${escapeHtml(latestTimes)}</div>` : ''}${f.reservationNumber ? `<div>予約番号：${escapeHtml(f.reservationNumber)}</div>` : ''}${f.terminal || f.gate ? `<div>ターミナル：${escapeHtml(f.terminal || '—')}　ゲート：${escapeHtml(f.gate || '—')}</div>` : ''}${source ? `<div><b>確認元：</b>${source}</div>` : ''}${f.checkNote ? `<div class="flight-check-note">${escapeHtml(f.checkNote)}</div>` : ''}${f.lastCheckedAt ? `<small>最終確認：${escapeHtml(formatJstTimestamp(f.lastCheckedAt))}</small>` : ''}${isEditor() ? `<div class="flight-actions"><button type="button" class="btn small" data-check-flight="${escapeHtml(f.id)}">この便を確認</button></div>` : ''}</div>`;
}

function currentMonthSchedules() {
  const key = `${state.viewMonth.getFullYear()}-${String(state.viewMonth.getMonth() + 1).padStart(2, '0')}`;
  return filteredBase().filter((s) => s.date.startsWith(key));
}
function filteredBase() {
  const region = $('regionFilter')?.value || '';
  const purpose = $('purposeFilter')?.value || '';
  return state.data.schedules.filter((s) => (!region || s.regionId === region) && (!purpose || s.purposeId === purpose));
}
function modeSchedules() {
  let rows = filteredBase();
  if (state.mode === 'arrival') rows = rows.filter((s) => arrivalTotal(s) > 0);
  if (state.mode === 'departure') rows = rows.filter((s) => departureTotal(s) > 0);
  if (state.mode === 'incomplete') rows = rows.filter(isIncomplete);
  if (state.mode === 'personstore') {
    const employee = $('employeeFilter')?.value || '';
    const store = $('storeFilter')?.value || '';
    if (employee) rows = rows.filter((s) => s.employees?.includes(employee));
    if (store) rows = rows.filter((s) => s.stores?.some((r) => r.storeId === store));
  }
  return rows.sort((a, b) => `${a.date} ${a.departureTime || '99:99'}`.localeCompare(`${b.date} ${b.departureTime || '99:99'}`));
}

function renderSession() {
  const user = state.data.user;
  $('loginButton').hidden = !!user;
  $('logoutButton').hidden = !user;
  $('addScheduleButton').hidden = !isEditor();
  qsa('.admin-only').forEach((el) => { el.hidden = !isAdmin(); });
  $('sessionLabel').textContent = user ? `${user.username} / ${user.role === 'admin' ? '完全編集' : user.role === 'manager' ? '予定管理' : user.role === 'time_editor' ? '出発時間のみ' : user.role}` : '一般閲覧';
  const u = state.data.usage || {};
  $('usageLabel').textContent = `OCR ${u.vision || 0}/${u.visionLimit || 900}・AI解析 ${u.openai || 0}/${u.openaiLimit || 300}・Web確認 ${u.openaiWeb || 0}/${u.openaiWebLimit || 100}・AeroAPI ${u.flight || 0}/${u.flightLimit || 300}`;
}
function renderFilters() {
  const regionValue = $('regionFilter').value;
  const purposeValue = $('purposeFilter').value;
  const employeeValue = $('employeeFilter').value;
  const storeValue = $('storeFilter').value;
  $('regionFilter').innerHTML = `<option value="">すべて</option>${state.data.regions.map((x) => `<option value="${escapeHtml(x.id)}">${escapeHtml(x.name)}</option>`).join('')}`;
  $('purposeFilter').innerHTML = `<option value="">すべて</option>${state.data.purposes.map((x) => `<option value="${escapeHtml(x.id)}">${escapeHtml(x.name)}</option>`).join('')}`;
  $('employeeFilter').innerHTML = `<option value="">すべて</option>${state.data.employees.filter((x) => x.active).map((x) => `<option value="${escapeHtml(x.id)}">${escapeHtml(x.name)}</option>`).join('')}`;
  $('storeFilter').innerHTML = `<option value="">すべて</option>${state.data.stores.filter((x) => x.active).map((x) => `<option value="${escapeHtml(x.id)}">${escapeHtml(x.name)}</option>`).join('')}`;
  if ([...$('regionFilter').options].some((o) => o.value === regionValue)) $('regionFilter').value = regionValue;
  if ([...$('purposeFilter').options].some((o) => o.value === purposeValue)) $('purposeFilter').value = purposeValue;
  if ([...$('employeeFilter').options].some((o) => o.value === employeeValue)) $('employeeFilter').value = employeeValue;
  if ([...$('storeFilter').options].some((o) => o.value === storeValue)) $('storeFilter').value = storeValue;
  const named = state.mode === 'personstore';
  $('employeeFilterWrap').hidden = !named;
  $('storeFilterWrap').hidden = !named;
}
function renderStats() {
  const rows = currentMonthSchedules();
  $('arrivalStat').textContent = String(rows.reduce((n, s) => n + arrivalTotal(s), 0));
  $('departureStat').textContent = String(rows.reduce((n, s) => n + departureTotal(s), 0));
  $('incompleteStat').textContent = String(rows.filter(isIncomplete).length);
}

function dateInRange(date, start, end) { return date >= start && date <= end; }
function renderCalendar() {
  const y = state.viewMonth.getFullYear();
  const m = state.viewMonth.getMonth();
  $('monthLabel').textContent = `${y}年${m + 1}月`;
  const first = new Date(y, m, 1);
  const start = new Date(y, m, 1 - first.getDay());
  const rows = filteredBase();
  const holidayMap = new Map(state.data.holidays.map((x) => [x.date, x.name]));
  const today = localDateString(new Date());
  const html = [];
  for (let i = 0; i < 42; i += 1) {
