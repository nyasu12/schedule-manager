        if (aeroAuthError(routeSchedule)) return fail('FlightAware AeroAPIキーまたは契約権限を確認してください。', 502, routeSchedule.data?.title || routeSchedule.data?.error || routeSchedule.response.status);
        if (aeroRateError(routeSchedule)) return fail('FlightAware AeroAPIのレート上限に達しました。時間を置いて再試行してください。', 429);
        if (routeSchedule.response.ok) {
          const candidates = possibleChangeCandidates(routeSchedule.data, row, 'scheduled');
          if (candidates.length) {
            const note = await applyPossibleChangeCheck(env, id, row, candidates);
            return json({
              ok: true, source: 'AeroAPI公開スケジュール', matchType: 'possible_change', requiresReview: true,
              candidates, note, used: latestAeroUsage, limit: aeroLimit,
              flight: { id, status: '便変更の可能性あり', checkSource: 'AeroAPI公開スケジュール', checkNote: note, lastCheckedAt: nowIso() },
            });
          }
          warnings.push('同日・同一路線の別便候補も確認できませんでした。');
        } else {
          warnings.push(`AeroAPI同一路線候補検索 HTTP ${routeSchedule.response.status}`);
        }
      } else {
        warnings.push(`AeroAPI公開スケジュール HTTP ${scheduled.response.status}`);
      }
    } catch (e) {
      if (/上限/.test(e?.message || '')) warnings.push(e.message);
      else warnings.push(e?.message || String(e));
    }
  } else {
    warnings.push('搭乗日が未入力のため、将来スケジュール検索は行いませんでした。');
  }

  // 3) AeroAPIに無い場合だけOpenAI Web検索。公式航空会社/空港サイトの一致候補だけ反映し、必ず「要目視」とする。
  if (env.OPENAI_API_KEY) {
    try {
      const web = await searchOfficialFlightWithOpenAI(env, row);
      if (web) {
        await applyFlightCheck(env, id, web);
        return json({ ok: true, source: web.source, matchType: 'official_web', requiresReview: true, flight: { id, ...web, lastCheckedAt: nowIso() }, used: latestAeroUsage, limit: aeroLimit, warnings });
      }
      warnings.push('公式航空会社・空港サイトでも条件が一致する情報を確認できませんでした。');
    } catch (e) {
      warnings.push(e?.message || String(e));
    }
  } else {
    warnings.push('OPENAI_API_KEY が未設定のためWeb検索は行いませんでした。');
  }

  return fail('指定日・便番号・出発地・到着地が一致する便を確認できませんでした。旅程表・登録時刻は変更していません。', 404, warnings.join(' / '));
}

export default {
  async fetch(request, env) {
    const url = new URL(request.url);
    const path = url.pathname;
    try {
      if (request.method === 'OPTIONS') return new Response(null, { status: 204 });
      if (path === '/api/health' && request.method === 'GET') return json({ ok: true, version: '0.4.0' });
      if (path === '/api/bootstrap' && request.method === 'GET') return await bootstrap(request, env);
      if (path === '/api/login' && request.method === 'POST') return await login(request, env);
      if (path === '/api/logout' && request.method === 'POST') return logout();
      if (path === '/api/ocr/preview' && request.method === 'POST') return await previewTravelDocument(request, env);
      if (path === '/api/schedules' && request.method === 'POST') return await saveSchedule(request, env);
      let match = path.match(/^\/api\/schedules\/([^/]+)\/departure-time$/);
      if (match && request.method === 'POST') return await updateDepartureTime(request, env, decodeURIComponent(match[1]));
      match = path.match(/^\/api\/schedules\/([^/]+)$/);
      if (match && request.method === 'DELETE') return await deleteSchedule(request, env, decodeURIComponent(match[1]));
      match = path.match(/^\/api\/schedules\/([^/]+)\/files$/);
      if (match && request.method === 'POST') return await uploadFile(request, env, decodeURIComponent(match[1]), url);
      match = path.match(/^\/api\/master\/(region|purpose|company|store|employee|car)$/);
      if (match && request.method === 'POST') return await saveMaster(request, env, match[1]);
      match = path.match(/^\/api\/master\/(region|purpose|company|store|employee|car)\/([^/]+)$/);
      if (match && request.method === 'DELETE') return await deactivateMaster(request, env, match[1], decodeURIComponent(match[2]));
      match = path.match(/^\/api\/files\/([^/]+)\/ocr$/);
      if (match && request.method === 'POST') return await runVision(request, env, decodeURIComponent(match[1]));
      match = path.match(/^\/api\/files\/([^/]+)$/);
      if (match && request.method === 'DELETE') return await deleteFile(request, env, decodeURIComponent(match[1]));
      match = path.match(/^\/api\/flights\/([^/]+)\/check$/);
      if (match && request.method === 'POST') return await checkFlight(request, env, decodeURIComponent(match[1]));
      match = path.match(/^\/files\/([^/]+)$/);
      if (match && request.method === 'GET') return await serveFile(env, decodeURIComponent(match[1]));
      if (path.startsWith('/api/')) return fail('APIが見つかりません。', 404);
      return await env.ASSETS.fetch(request);
    } catch (e) {
      console.error(e);
      return fail('サーバー処理でエラーが発生しました。', 500, e?.message || String(e));
    }
  },
};
