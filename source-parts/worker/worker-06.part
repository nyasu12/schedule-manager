 source: 'AeroAPI公開スケジュール',
    url: '',
    note: '航空会社が公開した将来スケジュールで、便番号・搭乗日・出発地・到着地が一致しました。実運航情報ではありません。',
  };
}
function officialWebUrl(value) {
  const raw = trim(value, 1000);
  if (!/^https?:\/\//i.test(raw)) return '';
  try {
    const host = new URL(raw).hostname.toLowerCase();
    const blocked = ['flightaware.com','flightradar24.com','google.com','bing.com','kayak.com','skyscanner.com','trip.com','expedia.com','facebook.com','x.com','twitter.com','wikipedia.org'];
    if (blocked.some((d) => host === d || host.endsWith(`.${d}`))) return '';
    return raw;
  } catch { return ''; }
}
function responseOutputText(data) {
  if (typeof data?.output_text === 'string' && data.output_text.trim()) return data.output_text.trim();
  const chunks = [];
  for (const item of Array.isArray(data?.output) ? data.output : []) {
    if (item?.type !== 'message') continue;
    for (const c of Array.isArray(item.content) ? item.content : []) {
      if (c?.type === 'output_text' && typeof c.text === 'string') chunks.push(c.text);
      else if (typeof c?.text === 'string') chunks.push(c.text);
    }
  }
  return chunks.join('\n').trim();
}
function parseJsonObjectText(text) {
  const clean = String(text || '').replace(/^```(?:json)?\s*/i, '').replace(/```\s*$/i, '').trim();
  const a = clean.indexOf('{'), b = clean.lastIndexOf('}');
  if (a < 0 || b <= a) return null;
  try { return JSON.parse(clean.slice(a, b + 1)); } catch { return null; }
}
function webFlightMatches(row, parsed) {
  if (!parsed?.found || !parsed?.official_source) return false;
  if (row.flight_date && normalizeDate(parsed.flight_date) !== row.flight_date) return false;
  const fake = {
    ident_iata: parsed.flight_number || '',
    origin_iata: parsed.origin || '',
    destination_iata: parsed.destination || '',
    scheduled_out: parsed.flight_date ? `${parsed.flight_date}T12:00:00Z` : '',
  };
  if (!identMatches(row, fake)) return false;
  if (row.origin && !airportMatches(row.origin, parsed.origin)) return false;
  if (row.destination && !airportMatches(row.destination, parsed.destination)) return false;
  return true;
}
async function searchOfficialFlightWithOpenAI(env, row) {
  if (!env.OPENAI_API_KEY || !row.flight_date || !targetIdent(row)) return null;
  const used = await getUsage(env, 'openai_web');
  const limit = safeInt(env.OPENAI_WEB_MONTHLY_LIMIT, 100);
  if (used >= limit) throw new Error(`OpenAI Web確認のアプリ内上限（${limit}回/月）に達しました。`);
  const model = trim(env.OPENAI_WEB_MODEL || 'gpt-5.4-nano', 80) || 'gpt-5.4-nano';
  const ident = targetIdent(row);
  const prompt = [
    'You are verifying one airline flight for an airport-transfer operations app.',
    'Use web search. Use ONLY an official airline website or an official departure/arrival airport website as evidence.',
    'Do not use FlightAware, Flightradar24, Google snippets, travel agencies, blogs, social media, Wikipedia, or other aggregators as the source.',
    'The flight must match the requested flight number, requested travel date, origin and destination. If any required item cannot be verified from an official source, return found=false.',
    'Never substitute a nearby date, a codeshare with a different route, or a different flight just because it looks similar.',
    'Times must be local airport times in HH:MM. Return empty strings for details the official source does not show.',
    'Return exactly one JSON object and no markdown.',
    '{"found":true,"official_source":true,"flight_number":"Z2191","flight_date":"2026-10-28","origin":"NRT","destination":"MNL","scheduled_departure":"11:25","scheduled_arrival":"15:20","terminal":"","gate":"","status":"scheduled","source_name":"AirAsia official","source_url":"https://...","note":""}',
    '',
    `Requested flight: ${ident}`,
    `Date: ${row.flight_date}`,
    `Origin: ${row.origin || '(unknown)'}`,
    `Destination: ${row.destination || '(unknown)'}`,
    `Ticket departure time: ${row.scheduled_departure || '(unknown)'}`,
    `Ticket arrival time: ${row.scheduled_arrival || '(unknown)'}`,
  ].join('\n');
  const response = await fetch('https://api.openai.com/v1/responses', {
    method: 'POST',
    headers: { authorization: `Bearer ${env.OPENAI_API_KEY}`, 'content-type': 'application/json' },
    body: JSON.stringify({ model, tools: [{ type: 'web_search' }], input: prompt, reasoning: { effort: 'low' }, max_output_tokens: 1200 }),
  });
  const data = await response.json().catch(() => ({}));
  await addUsage(env, 'openai_web', 1);
  if (!response.ok) throw new Error(`OpenAI Web確認に失敗しました: ${data?.error?.message || `HTTP ${response.status}`}`);
  const parsed = parseJsonObjectText(responseOutputText(data));
  if (!parsed || !webFlightMatches(row, parsed)) return null;
  const url = officialWebUrl(parsed.source_url);
  if (!url) return null;
  return {
    changedDeparture: normalizeTime(parsed.scheduled_departure),
    changedArrival: normalizeTime(parsed.scheduled_arrival),
    terminal: trim(parsed.terminal || row.terminal, 80),
    gate: trim(parsed.gate || row.gate, 80),
    status: 'Web公式情報確認（要目視）',
    source: trim(parsed.source_name, 120) || 'OpenAI Web検索（公式情報）',
    url,
    note: trim(parsed.note, 700) || 'OpenAI Web検索で公式サイトの一致候補を確認しました。リンク先を目視確認してください。',
    webUsed: used + 1,
    webLimit: limit,
  };
}

async function checkFlight(request, env, id) {
  const auth = await requireRole(request, env, ['manager','admin']);
  if (auth.response) return auth.response;
  if (!env.FLIGHTAWARE_API_KEY) return fail('FlightAware APIキーはまだ設定されていません。', 503);
  const row = await env.DB.prepare('SELECT * FROM app_flights_v2 WHERE id=?').bind(id).first();
  if (!row) return fail('フライトが見つかりません。', 404);
  const rawFlight = trim(row.flight_number, 30).replace(/\s/g, '');
  const airline = trim(row.airline_code, 10).replace(/\s/g, '').toUpperCase();
  if (!rawFlight) return fail('便名・番号を入力してから確認してください。');
  if (!/[A-Z]/i.test(rawFlight) && !airline) return fail('数字だけの便番号の場合は航空会社コードも入力してください。');
  const ident = targetIdent(row);
  const warnings = [];
  let latestAeroUsage = await getUsage(env, 'flight');
  const aeroLimit = safeInt(env.FLIGHT_MONTHLY_LIMIT, 300);

  // 1) 実運航ウィンドウ。指定日・経路まで一致した便だけ採用し、別日の flights[0] は絶対に使わない。
  try {
    const live = await aeroGet(env, `https://aeroapi.flightaware.com/aeroapi/flights/${encodeURIComponent(ident)}`);
    latestAeroUsage = live.used;
    if (aeroAuthError(live)) return fail('FlightAware AeroAPIキーまたは契約権限を確認してください。', 502, live.data?.title || live.data?.error || live.response.status);
    if (aeroRateError(live)) return fail('FlightAware AeroAPIのレート上限に達しました。時間を置いて再試行してください。', 429);
    if (live.response.ok) {
      const exact = pickExactAeroFlight(live.data, row, 'flights');
      if (exact) {
        const result = operationalResult(row, exact);
        await applyFlightCheck(env, id, result);
        return json({ ok: true, source: result.source, matchType: 'operational', flight: { id, ...result, lastCheckedAt: nowIso() }, used: latestAeroUsage, limit: aeroLimit });
      }
      warnings.push('AeroAPI実運航情報には、指定日・便番号・経路が一致する便がありませんでした。');
    } else {
      warnings.push(`AeroAPI実運航情報 HTTP ${live.response.status}`);
    }
  } catch (e) {
    if (/上限/.test(e?.message || '')) return fail(e.message, 429);
    warnings.push(e?.message || String(e));
  }

  // 2) 将来の航空会社公開スケジュール。対象日の前後もUTCずれ対策として検索し、ローカル出発日で厳密照合。
  if (row.flight_date) {
    try {
      const start = addIsoDays(row.flight_date, -1);
      const end = addIsoDays(row.flight_date, 2);
      const url = new URL(`https://aeroapi.flightaware.com/aeroapi/schedules/${start}/${end}`);
      if (airline) url.searchParams.set('airline', airline);
      const number = flightNumberOnly(row);
      if (number) url.searchParams.set('flight_number', number);
      const origin = bestAirportCode(row.origin);
      const destination = bestAirportCode(row.destination);
      if (origin) url.searchParams.set('origin', origin);
      if (destination) url.searchParams.set('destination', destination);
      url.searchParams.set('max_pages', '1');
      const scheduled = await aeroGet(env, url.toString());
      latestAeroUsage = scheduled.used;
      if (aeroAuthError(scheduled)) return fail('FlightAware AeroAPIキーまたは契約権限を確認してください。', 502, scheduled.data?.title || scheduled.data?.error || scheduled.response.status);
      if (aeroRateError(scheduled)) return fail('FlightAware AeroAPIのレート上限に達しました。時間を置いて再試行してください。', 429);
      if (scheduled.response.ok) {
        const exact = pickExactAeroFlight(scheduled.data, row, 'scheduled');
        if (exact) {
          const result = scheduleResult(row, exact);
          await applyFlightCheck(env, id, result);
          return json({ ok: true, source: result.source, matchType: 'schedule', flight: { id, ...result, lastCheckedAt: nowIso() }, used: latestAeroUsage, limit: aeroLimit });
        }
        warnings.push('AeroAPI公開スケジュールにも、指定日・便番号・経路が一致する便がありませんでした。');

        // 同日・同一路線に別便がある場合は「便変更の可能性あり」として候補だけ提示する。
        // 同じ路線に複数便が通常運航するケースがあるため、候補を自動で登録便に置き換えない。
        const candidateUrl = new URL(`https://aeroapi.flightaware.com/aeroapi/schedules/${start}/${end}`);
        if (airline) candidateUrl.searchParams.set('airline', airline);
        if (origin) candidateUrl.searchParams.set('origin', origin);
        if (destination) candidateUrl.searchParams.set('destination', destination);
        candidateUrl.searchParams.set('max_pages', '1');
        const routeSchedule = await aeroGet(env, candidateUrl.toString());
        latestAeroUsage = routeSchedule.used;
        if (aeroAuthError(routeSchedule)) return fail('FlightAware AeroAPIキーまたは契約権限を確認してください。', 502, routeSchedule.data?.title || routeSchedule.data?.error || routeSchedule.response.status);
        if (aeroRateError(routeSchedule)) return fail('FlightAware AeroAPIのレート上限に達しました。時間を置いて再試行してください。', 429);
        if (routeSchedule.response.ok) {
          const candidates = possibleChangeCandidates(routeSchedule.data, row, 'scheduled');
          if (candidates.length) {
            const note = await applyPossibleChangeCheck(env, id, row, candidates);
            return json({
              ok: true, source: 'AeroAPI公開スケジュール', matchType: 'possible_change', requiresReview: true,
              candidates, note, used: latestAeroUsage, limit: aeroLimit,
              flight: { id, status: '便変更の可能性あり', checkSource: 'AeroAPI公開スケジュール', checkNote: note, lastCheckedAt: nowIso() },
            });
          }
          warnings.push('同日・同一路線の別便候補も確認できませんでした。');
        } else {
          warnings.push(`AeroAPI同一路線候補検索 HTTP ${routeSchedule.response.status}`);
        }
      } else {
        warnings.push(`AeroAPI公開スケジュール HTTP ${scheduled.response.status}`);
      }
    } catch (e) {
      if (/上限/.test(e?.message || '')) warnings.push(e.message);
      else warnings.push(e?.message || String(e));
    }
  } else {
    warnings.push('搭乗日が未入力のため、将来スケジュール検索は行いませんでした。');
  }

  // 3) AeroAPIに無い場合だけOpenAI Web検索。公式航空会社/空港サイトの一致候補だけ反映し、必ず「要目視」とする。
  if (env.OPENAI_API_KEY) {
    try {
      const web = await searchOfficialFlightWithOpenAI(env, row);
      if (web) {
        await applyFlightCheck(env, id, web);
        return json({ ok: true, source: web.source, matchType: 'official_web', requiresReview: true, flight: { id, ...web, lastCheckedAt: nowIso() }, used: latestAeroUsage, limit: aeroLimit, warnings });
      }
      warnings.push('公式航空会社・空港サイトでも条件が一致する情報を確認できませんでした。');
    } catch (e) {
      warnings.push(e?.message || String(e));
    }
  } else {
    warnings.push('OPENAI_API_KEY が未設定のためWeb検索は行いませんでした。');
  }

  return fail('指定日・便番号・出発地・到着地が一致する便を確認できませんでした。旅程表・登録時刻は変更していません。', 404, warnings.join(' / '));
}

export default {
  async fetch(request, env) {
    const url = new URL(request.url);
    const path = url.pathname;
    try {
      if (request.method === 'OPTIONS') return new Response(null, { status: 204 });
      if (path === '/api/health' && request.method === 'GET') return json({ ok: true, version: '0.3.13' });